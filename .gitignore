# Secrets
.env
.env.*

# Raw benchmark logs (contain local paths, session IDs)
results/raw/
results/**/*_opencode.log
results/**/*_result.txt

# Workspace artifacts (ephemeral, wiped each run)
**/workspace/*
!**/workspace/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo

# Tool caches
.ruff_cache/
.pytest_cache/

# Databases
*.db

# OS
.DS_Store
